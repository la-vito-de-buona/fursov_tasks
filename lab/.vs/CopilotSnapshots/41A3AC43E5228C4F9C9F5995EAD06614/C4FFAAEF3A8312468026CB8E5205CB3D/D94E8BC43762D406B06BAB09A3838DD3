COORD GetCursorPosition() {
    CONSOLE_SCREEN_BUFFER_INFO IpCursorInfo;
    GetConsoleScreenBufferInfo(GetStdHandle(STD_ERROR_HANDLE), &IpCursorInfo);
    return IpCursorInfo.dwCursorPosition;
}



