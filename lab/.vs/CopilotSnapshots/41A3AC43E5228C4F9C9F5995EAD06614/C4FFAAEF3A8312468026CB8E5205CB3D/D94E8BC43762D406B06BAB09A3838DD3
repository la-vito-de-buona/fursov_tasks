float minn(float a, float b, float c, float d) {
    float mn = INFINITY;
    if (a < mn) mn = a;
    if (b < mn) mn = b;
    if (c < mn) mn = c;
    if (d < mn) mn = d;
    return(mn);
}

float arr_max(float s[], const int size)
{
    float mx = 0;

    for (int i = 0; i < size; i++) {
        if (s[i] > mx) mx = s[i];
    }
    return mx;
}

float arr_min(float s[], const int size) {
    float mn = INFINITY;
    for (int i = 0; i < size; i++) {
        if (s[i] < mn) mn = s[i];
    }
    return mn;
}

