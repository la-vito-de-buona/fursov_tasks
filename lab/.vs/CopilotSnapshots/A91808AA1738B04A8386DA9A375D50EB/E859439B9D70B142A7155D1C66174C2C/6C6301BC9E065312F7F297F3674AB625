bool inputBinary(string& value) {
    string buffer;
    char ch;
    bool error = false;

    COORD startPos = GetCursorPosition();

    while (true) {
        ch = _getch();

        if (ch == 27) {
            return false;
        }

        if (ch == 13) {
            try {
                if (buffer.empty()) {
                    throw runtime_error("empty");
                }

                for (char c : buffer) {
                    if (c != '0' && c != '1') {
                        throw runtime_error("invalid char");
                    }
                }

                if (error) {
                    SetCursorPosition(startPos.Y + 1, startPos.X);
                    cout << "\x1b[2K\r";
                    SetCursorPosition(startPos.Y, 0);
                }

                value = buffer;
                return true;
            }
            catch (...) {
                cout << "Ошибка! Повторите ввод: ";
                buffer.clear();
                error = true;
            }
        }
        else if (ch == 8) {
            if (!buffer.empty()) {
                buffer.pop_back();
                cout << "\b \b";
            }
        }
        else {
            if (ch == '0' || ch == '1') {
                buffer += ch;
                cout << ch;
            }
        }
    }
}

